{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": ["@angular/material"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "govpay-console": {
      "projectType": "application",
      "root": "projects/govpay-console",
      "sourceRoot": "projects/govpay-console/src",
      "prefix": "lnk",
      "schematics": {
        "@schematics/angular:class": { "skipTests": true },
        "@schematics/angular:component": {
          "skipTests": true,
          "changeDetection": "OnPush",
          "style": "css",
          "standalone": true
        },
        "@schematics/angular:directive": { "skipTests": true, "standalone": true },
        "@schematics/angular:guard": { "skipTests": true },
        "@schematics/angular:interceptor": { "skipTests": true },
        "@schematics/angular:pipe": { "skipTests": true, "standalone": true },
        "@schematics/angular:resolver": { "skipTests": true },
        "@schematics/angular:service": { "skipTests": true }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/govpay-console/src/main.ts",
            "tsConfig": "projects/govpay-console/tsconfig.app.json",
            "index": "projects/govpay-console/src/index.html",
            "polyfills": ["zone.js"],
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/govpay-console/public"
              },
              "projects/govpay-console/src/assets"
            ],
            "styles": [
              "projects/govpay-console/src/styles/fonts/prompt.css",
              "projects/govpay-console/src/styles.css"
            ],
            "outputPath": "dist/govpay-console"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "750kB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "govpay-console:build:production"
            },
            "development": {
              "buildTarget": "govpay-console:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
